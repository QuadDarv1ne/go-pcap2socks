# go-pcap2socks Environment Variables Example
# Скопируйте этот файл в .env и заполните значениями

# ============================================
# API Configuration
# ============================================

# API токен для аутентификации (минимум 16 символов)
# Рекомендуется использовать генератор паролей
API_TOKEN="your-super-secret-api-token-here"

# Порт API (по умолчанию 8080)
API_PORT=8080

# ============================================
# Telegram Bot (опционально)
# ============================================

# Токен бота от @BotFather
TELEGRAM_TOKEN="123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11"

# Chat ID для уведомлений (можно получить через @userinfobot)
TELEGRAM_CHAT_ID="123456789"

# ============================================
# Discord Webhook (опционально)
# ============================================

# Discord webhook URL для уведомлений
DISCORD_WEBHOOK_URL="https://discord.com/api/webhooks/..."

# ============================================
# Logging
# ============================================

# Уровень логирования: debug, info, warn, error
SLOG_LEVEL="info"

# ============================================
# Performance
# ============================================

# Лимит памяти (по умолчанию адаптивный)
# GOMEMLIMIT=512000000  # 512 MB

# Количество CPU ядер (по умолчанию все доступные)
# GOMAXPROCS=4

# ============================================
# Debug
# ============================================

# Включить pprof (0 или 1)
PPROF_ENABLED=0

# Порт для pprof (если включен)
PPROF_PORT=6060

# ============================================
# Network
# ============================================

# Интерфейс для захвата трафика (опционально)
# PCAP_INTERFACE="Ethernet"

# Статический IP для шлюза (опционально)
# PCAP_GATEWAY="192.168.100.1"

# ============================================
# Security
# ============================================

# Включить HTTPS для веб-интерфейса (true/false)
API_HTTPS_ENABLED=false

# Автоматическая генерация SSL сертификатов
API_HTTPS_AUTOTLS=true

# Принудительный редирект HTTP → HTTPS
API_HTTPS_FORCE=false

# ============================================
# Feature Flags
# ============================================

# Включить DHCP сервер
DHCP_ENABLED=true

# Включить UPnP
UPNP_ENABLED=true

# Включить балансировку WAN
WAN_BALANCER_ENABLED=false

# ============================================
# Metrics
# ============================================

# Включить Prometheus метрики
METRICS_ENABLED=true

# Порт для метрик (если отдельный от API)
# METRICS_PORT=9090
